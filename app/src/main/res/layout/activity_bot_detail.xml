<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/text_primary"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Status Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/card_border"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvEntryFile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>

            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="▶  START"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/status_running"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_marginEnd="6dp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="■  STOP"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/status_crashed"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_marginEnd="6dp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btnRestart"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="↺  RESTART"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/accent_blue"
                    style="@style/Widget.MaterialComponents.Button"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Log Controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⬛  CONSOLE"
                    android:textColor="@color/terminal_green"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"/>

                <Button
                    android:id="@+id/btnRefreshLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Refresh"
                    android:textSize="11sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnClearLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Clear"
                    android:textSize="11sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            </LinearLayout>

            <!-- Terminal Log View -->
            <ScrollView
                android:id="@+id/scrollLogs"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:background="@color/log_bg">

                <TextView
                    android:id="@+id/tvLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="(loading…)"
                    android:textColor="@color/terminal_green"
                    android:textSize="11.5sp"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:lineSpacingMultiplier="1.4"
                    android:textIsSelectable="true"/>

            </ScrollView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
