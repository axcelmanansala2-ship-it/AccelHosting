<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AccelHosting" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/accent_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorAccent">@color/accent_blue</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="toolbarStyle">@style/AccelToolbar</item>
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
        <item name="colorControlNormal">@color/text_secondary</item>
        <item name="colorControlActivated">@color/accent_blue</item>
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>
        <item name="swipeRefreshLayoutProgressSpinnerBackgroundColor">@color/bg_surface</item>
    </style>

    <style name="AccelToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/bg_surface</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <style name="StatCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/card_bg</item>
        <item name="android:padding">14dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="StatNumber">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="StatLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>
</resources>
